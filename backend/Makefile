# Hostel Management Backend — Makefile
# All recipes use tabs (required by make). Do not replace with spaces.

PYTHON ?= python
PIP ?= pip
FLASK ?= flask

.PHONY: help install install-dev run test test-cov migrate upgrade downgrade seed lint fmt

help:
	@echo "Targets:"
	@echo "  install       Install runtime dependencies"
	@echo "  install-dev   Install dev + runtime dependencies"
	@echo "  run           Start the Flask dev server"
	@echo "  test          Run the test suite"
	@echo "  test-cov      Run tests with coverage report"
	@echo "  migrate       Create a new Alembic migration (MSG=\"message\")"
	@echo "  upgrade       Apply pending migrations"
	@echo "  downgrade     Roll back one migration"
	@echo "  seed          Run scripts/seed.py"
	@echo "  lint          Run static checks (ruff if available)"
	@echo "  fmt           Format code (black + ruff --fix if available)"

install:
	$(PIP) install -r requirements.txt

install-dev:
	$(PIP) install -r requirements-dev.txt

run:
	$(FLASK) run --host=0.0.0.0 --port=5000

test:
	pytest

test-cov:
	pytest --cov=app --cov-report=term-missing --cov-report=html

migrate:
	$(FLASK) db migrate -m "$(or $(MSG),autogenerated migration)"

upgrade:
	$(FLASK) db upgrade

downgrade:
	$(FLASK) db downgrade

seed:
	$(PYTHON) scripts/seed.py

lint:
	@command -v ruff >/dev/null 2>&1 && ruff check app tests || echo "ruff not installed; skipping"

fmt:
	@command -v black >/dev/null 2>&1 && black app tests || echo "black not installed; skipping"
	@command -v ruff >/dev/null 2>&1 && ruff check --fix app tests || echo "ruff not installed; skipping"
