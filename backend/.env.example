# =========================================================================
# Hostel Management Backend — Environment Configuration
# =========================================================================
# Copy this file to `.env` and replace placeholder values with real secrets
# BEFORE running the app. Never commit `.env` to git.
# =========================================================================

# ---- Runtime -------------------------------------------------------------
# One of: development | testing | production
APP_ENV=development

# Flask secret key. MUST be 32+ random bytes in production.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-32-byte-secret

# ---- JWT -----------------------------------------------------------------
# Separate from SECRET_KEY so token signing can be rotated independently.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-32-byte-jwt-secret
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# ---- Database ------------------------------------------------------------
# PostgreSQL connection URL. The app rewrites `postgres://` -> `postgresql://`.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://hostel:hostel@localhost:5432/hostel_dev

# Optional separate database for pytest. Falls back to DATABASE_URL if unset.
TEST_DATABASE_URL=postgresql://hostel:hostel@localhost:5432/hostel_test

# ---- CORS ----------------------------------------------------------------
# Frontend origin used in links (password reset emails, etc.)
FRONTEND_URL=http://localhost:3000

# Comma-separated list of allowed origins. MUST NOT be `*` when cookies are
# used (refresh token cookie requires supports_credentials=True).
CORS_ORIGINS=http://localhost:3000

# ---- Rate Limiting -------------------------------------------------------
# memory:// for single-process dev. Use redis://host:port/0 for multi-worker.
RATELIMIT_STORAGE_URI=memory://

# ---- Payment Provider ----------------------------------------------------
# One of: mock | stripe | razorpay
PAYMENT_PROVIDER=mock

# HMAC secret for MockProvider webhook signature verification.
WEBHOOK_SECRET=change-me-mock-webhook-secret

# Stripe credentials (only required if PAYMENT_PROVIDER=stripe).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Razorpay credentials (only required if PAYMENT_PROVIDER=razorpay).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- Mail (SMTP) ---------------------------------------------------------
# Leave MAIL_SERVER empty to suppress actual sends in dev.
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@hostel.app
MAIL_USE_TLS=true

# ---- Business Rules ------------------------------------------------------
# Booking hold (how long a pending booking reserves a room) in minutes.
HOLD_TTL_MINUTES=30

# Password reset token lifetime in minutes.
PASSWORD_RESET_TTL_MINUTES=30

# Minimum password length enforced at registration/reset/change.
PASSWORD_MIN_LENGTH=8

# ---- Logging -------------------------------------------------------------
# One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ---- Internal Cron -------------------------------------------------------
# Shared secret for POST /api/v1/internal/expire-holds. Use a random 32+ byte
# token. The cron job must send it in the `X-Internal-API-Key` header.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=change-me-to-a-random-internal-api-key
